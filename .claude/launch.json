{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "livemeta.api.app:app", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "web-review",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev", "--", "--port", "5199", "--strictPort"],
      "port": 5199,
      "autoPort": false
    },
    {
      "name": "web-ci",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev:ci"],
      "port": 5210,
      "autoPort": false
    }
  ]
}
